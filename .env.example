# ============================================
# CONFIGURACION DEL PROYECTO
# ============================================
# Copia este archivo como .env y llena los valores

# Credenciales de Supabase (obtener de supabase.com -> Settings -> API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Email del superadmin (acceso total al sistema, panel tecnico)
VITE_SUPERADMIN_EMAIL=superadmin@tuempresa.com


# ============================================
# MÓDULO DE AUDITORÍA — IA de Vouchers
# ============================================
# Clave de OpenAI para el análisis de comprobantes con GPT-4o Vision.
# Esta clave NUNCA va en el frontend — se guarda como secreto en Supabase.
# Para configurarla en localhost:
#   supabase secrets set OPENAI_API_KEY=sk-...
# Para producción: Dashboard → Settings → Edge Functions → Secrets
# OPENAI_API_KEY=sk-proj-tu-clave-aqui
